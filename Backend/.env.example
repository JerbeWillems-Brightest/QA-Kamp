# Example environment variables for the backend
# Copy this file to `.env` and fill the real secrets. DO NOT commit `.env`.

# MongoDB connection (example for Atlas)
MONGO_URI=

# Organizer seed users (used by seedOrganizers if no organizers exist)
# Example:
# ORGANIZER1_EMAIL=
# ORGANIZER1_PASSWORD=
ORGANIZER1_EMAIL=
ORGANIZER1_PASSWORD=

ORGANIZER2_EMAIL=
ORGANIZER2_PASSWORD=

# JWT secret for auth tokens
JWT_SECRET=

# Frontend origin allowed for CORS (optional)
FRONTEND_ORIGIN=

