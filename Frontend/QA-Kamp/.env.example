# Backend API URL
# For local development with Vite proxy: leave empty or comment out
# VITE_API_URL=

# For production (Vercel or other hosting):
# VITE_API_URL=
# VITE_API_URL_DEV=

# NOTE: Do NOT include /api at the end — the app will append /api/status automatically

# If you host the frontend on a develop preview domain and want it to talk to the
# develop backend preview, set VITE_API_URL_DEV to the backend preview URL above.
# Example usage in local dev: create a .env.local with:
# VITE_API_URL_DEV=https://qa-kamp-backend-git-develop-jerbewillems-brightests-projects.vercel.app
# Then the frontend code can read import.meta.env.VITE_API_URL_DEV and use it when running
# against the develop preview.

# Optional: for preview detection, list the frontend preview domains (comma-separated)
# VITE_FRONTEND_DEV=https://qa-kamp-git-develop-jerbewillems-brightests-projects.vercel.app,https://qa-kamp-cfi6u4apr-jerbewillems-brightests-projects.vercel.app
